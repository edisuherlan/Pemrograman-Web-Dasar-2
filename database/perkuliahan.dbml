// Database: perkuliahan — selaras dengan database/perkuliahan.sql
// Tempel di editor: https://dbdiagram.io/ (format DBML)

Project perkuliahan {
  database_type: 'MySQL'
  Note: '''
    Praktikum Pemrograman Web 2 — ERD akademik (5 tabel).
    Impor SQL: database/perkuliahan.sql
  '''
}

Table dosen {
  id_dosen int [pk, increment, note: 'UNSIGNED']
  nidn varchar(20) [not null, unique]
  nama varchar(120) [not null]
  email varchar(120)
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  Note: 'Dosen pengampu mata kuliah'
}

Table mahasiswa {
  id_mahasiswa int [pk, increment, note: 'UNSIGNED']
  nim varchar(20) [not null, unique]
  nama varchar(120) [not null]
  email varchar(120)
  angkatan int [not null, note: 'Kolom MySQL YEAR']
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  Note: 'Data mahasiswa'
}

Table matakuliah {
  id_mk int [pk, increment, note: 'UNSIGNED']
  kode_mk varchar(20) [not null, unique]
  nama_mk varchar(160) [not null]
  sks tinyint [not null, default: 3, note: 'UNSIGNED']
  id_dosen int [not null]
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  indexes {
    id_dosen
  }
  Note: 'Mata kuliah; wajib satu dosen pengampu'
}

Table krs {
  id_krs int [pk, increment, note: 'UNSIGNED']
  id_mahasiswa int [not null]
  id_mk int [not null]
  semester varchar(10) [not null, note: "MySQL ENUM: 'gasal','genap'"]
  tahun_ajaran varchar(9) [not null, note: 'Format YYYY/YYYY']
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  indexes {
    (id_mahasiswa, id_mk, semester, tahun_ajaran) [unique, name: 'uq_krs_ambil']
    id_mahasiswa
    id_mk
  }
  Note: 'KRS: ambil MK per semester & tahun ajaran'
}

Table nilai {
  id_nilai int [pk, increment, note: 'UNSIGNED']
  id_krs int [not null, unique]
  nilai_angka decimal(5,2) [not null]
  nilai_huruf char(2) [not null]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`, note: 'MySQL: ON UPDATE CURRENT_TIMESTAMP']
  Note: 'Satu baris nilai per KRS (1:1)'
}

// Relasi: anak > induk (many-to-one), atau "-" untuk one-to-one
Ref: matakuliah.id_dosen > dosen.id_dosen [delete: restrict, update: cascade]

Ref: krs.id_mahasiswa > mahasiswa.id_mahasiswa [delete: cascade, update: cascade]

Ref: krs.id_mk > matakuliah.id_mk [delete: restrict, update: cascade]

// 1:1 — kolom kedua (id_krs di nilai) adalah FK
Ref: krs.id_krs - nilai.id_krs [delete: cascade, update: cascade]
